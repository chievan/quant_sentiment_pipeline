+LOG_FILE="$PROJECT_DIR/data/run.log"
+
+# 设置环境变量
+export SMTP_SERVER="smtp.163.com"
+export SMTP_PORT="465"
+export MAIL_USERNAME="wuqiwen0571@163.com"
